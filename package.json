{
  "name": "reverse-shell-generator",
  "title": "Reverse Shell Generator",
  "description": "Generate reverse shell commands for penetration testing and security research",
  "icon": "extension-icon.png",
  "author": "gandli",
  "categories": [
    "Security"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "generate-reverse-shell",
      "title": "Generate Reverse Shell",
      "description": "Generate reverse shell commands for various shell types",
      "mode": "view",
      "keywords": [
        "reverse",
        "shell",
        "netcat",
        "bash",
        "python",
        "pentest",
        "security"
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.5.4",
    "@types/react": "19.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish": "npx @raycast/api@latest publish",
    "pull": "npx @raycast/api@latest pull-contributions"
  },
  "overrides": {
    "minimatch": "^9.0.5"
  }
}
